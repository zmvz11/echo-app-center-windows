{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-electron",
    "rootDir": "src/desktop",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/desktop/**/*.ts",
    "src/types/electron-shim.d.ts"
  ]
}
