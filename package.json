{
  "name": "echo-app-center",
  "version": "1.2.1",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:agent": "tsx watch src/local-agent/index.ts",
    "build": "tsc -p tsconfig.app.json && vite build && tsc -p tsconfig.agent.json && tsc -p tsconfig.electron.json",
    "start:agent": "node dist-agent/local-agent/index.js",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.agent.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "node scripts/lint-project.mjs",
    "final-check": "node scripts/final-check.mjs",
    "package:windows": "npm run build && electron-builder --win nsis --x64",
    "start:desktop": "electron dist-electron/main.js",
    "desktop": "npm run start:desktop"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.16.2",
    "vite": "^8.0.16",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.echoapps.appcenter",
    "productName": "Echo App Center",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-agent/**/*",
      "dist-electron/**/*",
      "package.json",
      "README.md",
      "LICENSE"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Echo App Center",
      "perMachine": false,
      "allowElevation": true,
      "deleteAppDataOnUninstall": false
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "description": "Standalone desktop client for browsing, installing, launching, and updating Echo apps from Echo App Server.",
  "author": "Echo Apps"
}
